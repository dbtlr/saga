SAGA_DATABASE_URL_FILE=/run/secrets/saga_database_url
SAGA_ENV=production
SAGA_LOG_LEVEL=info
SAGA_SERVICE_HOST=0.0.0.0
# A non-loopback bind requires this ack: the deployment perimeter (the port
# publish), not the 0.0.0.0 bind, is the exposure boundary (ADR-0051).
SAGA_SERVICE_UNSAFE_ALLOW_NONLOOPBACK=1
SAGA_SERVICE_PORT=4766
# OPENAI_API_KEY_FILE=/run/secrets/openai_api_key
