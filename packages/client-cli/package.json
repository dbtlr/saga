{
  "name": "@saga/client-cli",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "saga-client": "./bin/saga-client.js"
  },
  "type": "module",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
