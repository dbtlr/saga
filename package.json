{
  "name": "saga-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Postgres-backed workspace memory system for agentic work.",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "deps:down": "docker compose -f docker-compose.local.yml down",
    "deps:logs": "docker compose -f docker-compose.local.yml logs -f",
    "deps:reset": "docker compose -f docker-compose.local.yml down -v && docker compose -f docker-compose.local.yml up -d --wait",
    "deps:up": "docker compose -f docker-compose.local.yml up -d --wait",
    "check": "vp check",
    "format": "vp format",
    "lint": "vp lint",
    "staged": "vp staged",
    "test": "vp test run --passWithNoTests",
    "verify": "pnpm run check && pnpm run test"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "oxlint": "^1.70.0",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "vite-plus": "^0.2.1",
    "vitest": "4.1.9"
  },
  "engines": {
    "node": ">=24.0.0 <27.0.0",
    "pnpm": "^11.0.0"
  },
  "packageManager": "pnpm@11.8.0"
}
